{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-favorites.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account section-{{ section.id }}-padding" {{ section.shopify_attributes }}>
  <div class="page-width">
    <h1 class="customer__title">{{ 'customer.favorites.title' | t }}</h1>

    {%- if customer -%}
      {%- assign fav_metafield = customer.metafields.custom.favorites -%}
      {%- assign fav_values = fav_metafield.value -%}
      {%- if fav_metafield != blank and fav_values != blank and fav_values.size > 0 -%}
        <div class="favorites-grid favorites-grid--from-metafield" data-favorites-server>
          {%- for handle in fav_values -%}
            {%- assign fav_product = all_products[handle] -%}
            {%- if fav_product != blank -%}
              <div class="favorites-grid__item">
                {% render 'card-product', card_product: fav_product, show_secondary_image: true %}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div id="favorites-root" class="favorites-grid favorites-grid--from-storage" data-customer-id="{{ customer.id }}">
          <p class="favorites-empty" data-favorites-empty>{{ 'customer.favorites.empty' | t }}</p>
        </div>
      {%- endif -%}
    {%- else -%}
      <p class="favorites-login-prompt">
        {{ 'customer.favorites.login_prompt_html' | t: link: routes.account_login_url }}
      </p>
      <div id="favorites-root" class="favorites-grid favorites-grid--from-storage" data-customer-id="0">
        <p class="favorites-empty" data-favorites-empty>{{ 'customer.favorites.empty' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    var FAVORITES_KEY = 'dawn_favorites';
    var root = document.getElementById('favorites-root');
    var fromServer = document.querySelector('[data-favorites-server]');
    if (!root || fromServer) return;

    function getFavorites() {
      try {
        var raw = localStorage.getItem(FAVORITES_KEY);
        var arr = raw ? JSON.parse(raw) : [];
        return Array.isArray(arr) ? arr : [];
      } catch (e) { return []; }
    }

    var items = getFavorites();
    var emptyEl = root.querySelector('[data-favorites-empty]');
    if (!items.length) {
      if (emptyEl) emptyEl.classList.add('favorites-empty--visible');
      return;
    }
    if (emptyEl) emptyEl.remove();
    var baseUrl = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    items.forEach(function(item) {
      var handle = (item.handle || '').trim();
      if (!handle) return;
      var link = document.createElement('a');
      link.href = baseUrl + 'products/' + handle;
      link.className = 'favorites-list__link';
      link.textContent = handle.replace(/-/g, ' ');
      var wrap = document.createElement('div');
      wrap.className = 'favorites-grid__item';
      wrap.appendChild(link);
      root.appendChild(wrap);
    });
  })();
</script>

{% schema %}
{
  "name": "Favorites",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
