{% comment %}
  Renders product buy-buttons.
  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} product form id.
  - section: {Object} section object (for gift wrap settings).
  - section_id: {String} id of section to which this snippet belongs.
  - show_pickup_availability: {Boolean} for the pickup availability. If true the pickup availability is rendered, false - not rendered (optional).

  Usage:
  {% render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section: section, section_id: section.id, show_pickup_availability: true %}
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      assign show_gift_card = block.settings.show_gift_card_recipient
      if show_gift_card != false and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout != false and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif
    -%}

    <product-form
      class="product-form"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section_id }}"
    >
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          {% if product.selected_or_first_available_variant.available == false
            or quantity_rule_soldout
            or product.selected_or_first_available_variant == null
          %}
            disabled
          {% endif %}
          class="product-variant-id"
        >

        {%- if gift_card_recipient_feature_active -%}
          <div id="ProductFormRecipient-{{ section.id }}" class="product-form__recipient-wrapper">
            {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
          </div>
        {%- endif -%}

        {%- liquid
          assign show_low_stock = true
          if block.settings.show_low_stock_alert == false
            assign show_low_stock = false
          endif
          assign giftwrap_enabled = true
          if block.settings.enable_giftwrap == false
            assign giftwrap_enabled = false
          endif
          assign giftwrap_price = block.settings.giftwrap_price | default: 1500
          assign variant = product.selected_or_first_available_variant
          assign inv_qty = variant.inventory_quantity | default: -1 | plus: 0
          assign stock_alert_visible = false
          if gift_card_recipient_feature_active == false and show_low_stock and inv_qty >= 1 and inv_qty < 10
            assign stock_alert_visible = true
          endif
        -%}

        {%- comment -%} Gift wrap option (Wrap as a gift?) — for non–gift-card products {%- endcomment -%}
        {%- if gift_card_recipient_feature_active == false and giftwrap_enabled -%}
          <div id="ProductFormGiftwrap-{{ section.id }}" class="product-form__gift-wrap-wrapper">
            {%- render 'giftwrap-add-on', product: product, section: section, enable_giftwrap: true, giftwrap_price: giftwrap_price, show_low_stock_alert: show_low_stock -%}
          </div>
        {%- endif -%}

        {%- comment -%} Standalone stock alert only when gift wrap is OFF (gift wrap has its own stock alert) {%- endcomment -%}
        {%- if gift_card_recipient_feature_active == false and show_low_stock and giftwrap_enabled == false -%}
          <div id="ProductFormStockAlert-{{ section.id }}" class="product-form__stock-alert{% unless stock_alert_visible %} product-form__stock-alert--empty{% endunless %}">
            {%- if stock_alert_visible -%}
              <span class="product-form__stock-dot" aria-hidden="true"></span>
              {{ 'giftwrap.stock_low_label' | t: count: inv_qty }}
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="product-form__buttons">
          <div class="product-form__buttons-inner">
            {%- liquid
              assign check_against_inventory = true
              if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
                assign check_against_inventory = false
              endif
              if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
                assign quantity_rule_soldout = true
              endif
            -%}
            <button
              id="ProductSubmitButton-{{ section_id }}"
              type="submit"
              name="add"
              class="product-form__submit button button--full-width {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
              {% if product.selected_or_first_available_variant.available == false
                or quantity_rule_soldout
                or product.selected_or_first_available_variant == null
              %}
                disabled
              {% endif %}
            >
              <span class="product-form__submit-text">
                {%- if product.selected_or_first_available_variant == null -%}
                  {{ 'products.product.unavailable' | t }}
                {%- elsif product.selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
                  {{ 'products.product.sold_out' | t }}
                {%- else -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- endif -%}
              </span>
              <span class="product-form__submit-arrow" aria-hidden="true">
                <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
              </span>
              {%- render 'loading-spinner' -%}
            </button>
            {%- if show_dynamic_checkout -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>
          <button
            type="button"
            class="product-form__favorite button button--tertiary"
            data-product-favorite
            data-product-id="{{ product.id }}"
            data-product-handle="{{ product.handle | escape }}"
            aria-label="{{ 'products.product.add_to_favorites' | t }}"
            aria-pressed="false"
            title="{{ 'products.product.add_to_favorites' | t }}"
          >
            <span class="product-form__favorite-icon" aria-hidden="true">
              {{- 'icon-heart.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
        {%- if customer -%}
          <p class="product-form__favorite-note product-form__favorite-note--logged-in">
            {{ 'products.product.favorites_saved_to_device' | t }}
            <a href="{{ shop.url }}/pages/favorites">{{ 'products.product.view_favorites' | t }}</a>
          </p>
        {%- else -%}
          <p class="product-form__favorite-note product-form__favorite-note--guest">
            {{ 'products.product.favorites_login_prompt_html' | t: link: routes.account_login_url }}
          </p>
        {%- endif -%}
        <script>
          (function() {
            var FAVORITES_KEY = 'dawn_favorites';
            var SYNC_URL = '{{ "apps/favorites/sync" | prepend: "/" }}';
            var CUSTOMER_ID = {{ customer.id | default: 0 }};
            function getFavorites() {
              try {
                var raw = localStorage.getItem(FAVORITES_KEY);
                var arr = raw ? JSON.parse(raw) : [];
                if (!Array.isArray(arr)) return [];
                return arr.map(function(o) {
                  if (o && typeof o === 'object' && o.id) return { id: String(o.id), handle: (o.handle || '').trim() };
                  return { id: String(o), handle: '' };
                });
              } catch (e) { return []; }
            }
            function setFavorites(items) {
              try { localStorage.setItem(FAVORITES_KEY, JSON.stringify(items)); } catch (e) {}
            }
            function syncToAccount(items) {
              if (!CUSTOMER_ID || !items || !items.length) return;
              try {
                fetch(SYNC_URL, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                  body: JSON.stringify({ customer_id: CUSTOMER_ID, items: items })
                }).catch(function() {});
              } catch (e) {}
            }
            function initFavorite(btn) {
              if (!btn || !btn.dataset.productId) return;
              var id = String(btn.dataset.productId);
              var handle = (btn.dataset.productHandle || '').trim();
              var favorites = getFavorites();
              var entry = favorites.find(function(o) { return o.id === id; });
              var isActive = !!entry;
              btn.setAttribute('aria-pressed', isActive);
              btn.classList.toggle('product-form__favorite--active', isActive);
              btn.setAttribute('aria-label', isActive ? {{ 'products.product.remove_from_favorites' | t | json }} : {{ 'products.product.add_to_favorites' | t | json }});
              btn.addEventListener('click', function() {
                var list = getFavorites();
                var idx = list.findIndex(function(o) { return o.id === id; });
                if (idx === -1) list.push({ id: id, handle: handle }); else list.splice(idx, 1);
                setFavorites(list);
                if (CUSTOMER_ID) syncToAccount(list);
                var active = list.some(function(o) { return o.id === id; });
                btn.setAttribute('aria-pressed', active);
                btn.classList.toggle('product-form__favorite--active', active);
                btn.setAttribute('aria-label', active ? {{ 'products.product.remove_from_favorites' | t | json }} : {{ 'products.product.add_to_favorites' | t | json }});
              });
            }
            var b = document.querySelector('[data-product-favorite][data-product-id="{{ product.id }}"]');
            if (b) initFavorite(b);
          })();
        </script>
      {%- endform -%}
    </product-form>
  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities quick-add-hidden"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
      data-product-page-color-scheme="gradient color-{{ section.settings.color_scheme }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
          <span class="svg-wrapper">
            {{- 'icon-unavailable.svg' | inline_asset_content -}}
          </span>
          <div class="pickup-availability-info">
            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
            <button class="pickup-availability-button link link--text underlined-link">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>

    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>
