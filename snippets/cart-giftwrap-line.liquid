{% comment %}
  cart-giftwrap-line (Figma: Cart drawer gift block + inline edit form)

  Renders gift-wrap summary and, when Edit is clicked, an inline form (To, From, Gift message + Update).
  Accepts: cart_item (required), gift_wrap_display_price (optional - giá từ sản phẩm dịch vụ ẩn)
{% endcomment %}

{%- liquid
  assign gift_property_key  = 'giftwrap.property_key'  | t
  assign gift_property_yes  = 'giftwrap.property_value_yes' | t
  assign to_property        = 'giftwrap.to_property'    | t
  assign from_property      = 'giftwrap.from_property'  | t
  assign message_property   = 'giftwrap.message_property' | t

  assign is_giftwrapped = false
  for property in cart_item.properties
    if property.first == gift_property_key and property.last == gift_property_yes
      assign is_giftwrapped = true
    endif
  endfor
  if gift_wrap_display_price != blank
    assign giftwrap_display_price = gift_wrap_display_price
  else
    assign giftwrap_display_price = 1500 | money_without_trailing_zeros
  endif

  assign to_val = ''
  assign from_val = ''
  assign msg_val = ''
  for property in cart_item.properties
    case property.first
      when to_property
        assign to_val = property.last
      when from_property
        assign from_val = property.last
      when message_property
        assign msg_val = property.last
    endcase
  endfor
  assign line_index = cart_item.index | plus: 1
-%}

{%- if is_giftwrapped -%}
  <div
    class="cart-giftwrap-line"
    data-giftwrap-line
    data-line-index="{{ line_index }}"
    data-quantity="{{ cart_item.quantity }}"
    data-key-gift="{{ gift_property_key | escape }}"
    data-key-yes="{{ gift_property_yes | escape }}"
    data-key-to="{{ to_property | escape }}"
    data-key-from="{{ from_property | escape }}"
    data-key-message="{{ message_property | escape }}"
  >
    {%- comment -%} Hidden: current properties for this line (to merge on update) {%- endcomment -%}
    {%- for property in cart_item.properties -%}
      <input type="hidden" class="cart-giftwrap-line__prop" data-prop-key="{{ property.first | escape }}" data-prop-value="{{ property.last | escape }}">
    {%- endfor -%}

    <div class="cart-giftwrap-line__row cart-giftwrap-line__row--top">
      <div class="cart-giftwrap-line__label-wrap">
        <span class="cart-giftwrap-line__checkbox" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" width="20" height="20" aria-hidden="true">
            <rect width="20" height="20" rx="4" fill="currentColor"/>
            <path d="M4 10l4 4 8-8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="cart-giftwrap-line__label">{{ 'giftwrap.add_label' | t: price: giftwrap_display_price }}</span>
      </div>
      <button type="button" class="cart-giftwrap-line__edit" data-giftwrap-edit aria-label="{{ 'giftwrap.edit_aria_label' | t: product: cart_item.product.title }}">
        {{ 'giftwrap.edit_label' | t }}
        <span class="cart-giftwrap-line__edit-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="none" width="12" height="12">
            <path d="M8.5 1.5l2 2-6.5 6.5H2v-2l6.5-6.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>
      <button type="button" class="cart-giftwrap-line__cancel cart-giftwrap-line__cancel--top" data-giftwrap-cancel aria-label="{{ 'giftwrap.cancel_label' | t }}">
        {{ 'giftwrap.cancel_label' | t }}
        <span class="cart-giftwrap-line__cancel-icon" aria-hidden="true">
          {{- 'icon-close-small.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>

    <div class="cart-giftwrap-line__message" data-giftwrap-message>
      {%- if to_val != blank or from_val != blank or msg_val != blank -%}
        {%- if to_val != blank -%}{{ 'giftwrap.to_label' | t }}: {{ to_val | escape }}{%- endif -%}
        {%- if from_val != blank -%}{% if to_val != blank %} / {% endif %}{{ 'giftwrap.from_label' | t }}: {{ from_val | escape }}{%- endif -%}
        {%- if msg_val != blank -%}{% if to_val != blank or from_val != blank %} / {% endif %}&ldquo;{{ msg_val | escape }}&rdquo;{%- endif -%}
      {%- endif -%}
    </div>

    <div class="cart-giftwrap-line__form" data-giftwrap-form aria-hidden="true">
      <div class="cart-giftwrap-line__form-inner">
      <div class="cart-giftwrap-line__field">
        <label class="cart-giftwrap-line__field-label" for="giftwrap-drawer-to-{{ line_index }}">{{ 'giftwrap.to_label' | t }}</label>
        <input type="text" id="giftwrap-drawer-to-{{ line_index }}" class="cart-giftwrap-line__input" data-giftwrap-to placeholder="{{ 'giftwrap.to_placeholder' | t }}" value="{{ to_val | escape }}" autocomplete="off">
      </div>
      <div class="cart-giftwrap-line__field">
        <label class="cart-giftwrap-line__field-label" for="giftwrap-drawer-from-{{ line_index }}">{{ 'giftwrap.from_label' | t }}</label>
        <input type="text" id="giftwrap-drawer-from-{{ line_index }}" class="cart-giftwrap-line__input" data-giftwrap-from placeholder="{{ 'giftwrap.from_placeholder' | t }}" value="{{ from_val | escape }}" autocomplete="off">
      </div>
      <div class="cart-giftwrap-line__field">
        <label class="cart-giftwrap-line__field-label" for="giftwrap-drawer-msg-{{ line_index }}">{{ 'giftwrap.message_label' | t }}</label>
        <textarea id="giftwrap-drawer-msg-{{ line_index }}" class="cart-giftwrap-line__textarea" data-giftwrap-message-input rows="4" placeholder="{{ 'giftwrap.message_placeholder' | t }}" autocomplete="off">{{ msg_val | escape }}</textarea>
      </div>
      <div class="cart-giftwrap-line__form-actions">
        <button type="button" class="button button--primary cart-giftwrap-line__update" data-giftwrap-update>{{ 'giftwrap.update_label' | t }}</button>
      </div>
      </div>
    </div>
  </div>
{%- endif -%}
