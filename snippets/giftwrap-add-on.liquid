{% comment %}
  giftwrap-add-on

  A self-contained gift-wrap upsell block for the product page buy-box.
  Renders a checkbox to opt-in to gift wrapping. When checked, an
  expandable form collects the recipient name, sender name and a message
  as Shopify cart line item properties.

  Design matches Figma: clean checkbox row (no large chevron), optional
  "Only 3 left!" stock message, form with To / From / Gift message.

  Accepts:
  - product: {Object} - The current product object (required)
  - section: {Object} - The parent section object, used to read settings (required)

  Usage:
  {% render 'giftwrap-add-on', product: product, section: section %}
{% endcomment %}

{%- liquid
  assign enable_giftwrap = section.settings.enable_giftwrap | default: true
  assign gift_price_setting = section.settings.giftwrap_price | default: 1500
  assign display_price = gift_price_setting | money
  assign stock_message = section.settings.giftwrap_stock_message | default: ''
  assign show_stock_message = section.settings.show_giftwrap_stock_message | default: false
-%}

{%- if enable_giftwrap -%}
  <div class="giftwrap-add-on" data-giftwrap-addon>
    {%- comment -%} Row: checkbox + label + optional "Only 3 left!" (no chevron) {%- endcomment -%}
    <div class="giftwrap-add-on__row">
      <label class="giftwrap-add-on__label" for="giftwrap-checkbox-{{ section.id }}">
        <input
          type="checkbox"
          id="giftwrap-checkbox-{{ section.id }}"
          name="properties[{{ 'giftwrap.property_key' | t }}]"
          value="{{ 'giftwrap.property_value_yes' | t }}"
          class="giftwrap-add-on__checkbox"
          data-giftwrap-checkbox
          aria-controls="giftwrap-form-{{ section.id }}"
          aria-expanded="false"
        >
        <span class="giftwrap-add-on__box-wrap">
          <span class="giftwrap-add-on__box" aria-hidden="true"></span>
          <span class="giftwrap-add-on__check" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 10 8" fill="none" width="10" height="8" aria-hidden="true">
              <path d="M1 4l2.5 2.5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </span>
        <span class="giftwrap-add-on__text">{{ 'giftwrap.add_label' | t: price: display_price }}</span>
      </label>
      {%- if show_stock_message and stock_message != blank -%}
        <span class="giftwrap-add-on__stock">
          <span class="giftwrap-add-on__stock-dot" aria-hidden="true"></span>
          {{ stock_message }}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%} Expandable form (shown when checkbox checked via CSS :has) {%- endcomment -%}
    <div id="giftwrap-form-{{ section.id }}" class="giftwrap-add-on__form" data-giftwrap-form>
      <div class="giftwrap-add-on__field">
        <label class="giftwrap-add-on__field-label" for="giftwrap-to-{{ section.id }}">{{ 'giftwrap.to_label' | t }}</label>
        <input
          type="text"
          id="giftwrap-to-{{ section.id }}"
          name="properties[{{ 'giftwrap.to_property' | t }}]"
          placeholder="{{ 'giftwrap.to_placeholder' | t }}"
          class="giftwrap-add-on__input"
          autocomplete="off"
        >
      </div>
      <div class="giftwrap-add-on__field">
        <label class="giftwrap-add-on__field-label" for="giftwrap-from-{{ section.id }}">{{ 'giftwrap.from_label' | t }}</label>
        <input
          type="text"
          id="giftwrap-from-{{ section.id }}"
          name="properties[{{ 'giftwrap.from_property' | t }}]"
          placeholder="{{ 'giftwrap.from_placeholder' | t }}"
          class="giftwrap-add-on__input"
          autocomplete="off"
        >
      </div>
      <div class="giftwrap-add-on__field">
        <label class="giftwrap-add-on__field-label" for="giftwrap-message-{{ section.id }}">{{ 'giftwrap.message_label' | t }}</label>
        <textarea
          id="giftwrap-message-{{ section.id }}"
          name="properties[{{ 'giftwrap.message_property' | t }}]"
          placeholder="{{ 'giftwrap.message_placeholder' | t }}"
          rows="4"
          class="giftwrap-add-on__textarea"
        ></textarea>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var el = document.querySelector('[data-giftwrap-addon]');
      if (!el) return;
      var checkbox = el.querySelector('[data-giftwrap-checkbox]');
      var form = el.querySelector('[data-giftwrap-form]');
      if (!checkbox || !form) return;
      function update() {
        var open = checkbox.checked;
        checkbox.setAttribute('aria-expanded', open);
        el.classList.toggle('giftwrap-add-on--open', open);
      }
      checkbox.addEventListener('change', update);
      update();
    })();
  </script>
{%- endif -%}
