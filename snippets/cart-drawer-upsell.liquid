{% comment %}
  Cart drawer upsell - "You may also like" block
  Uses Shopify Product Recommendations API based on the first item in the cart.
{% endcomment %}

{%- if cart != empty and cart.items.first.product_id -%}
  <cart-drawer-recommendations class="cart-drawer-upsell" data-cart-drawer-upsell data-url="{{ routes.product_recommendations_url }}?section_id=cart-drawer-recommendations&product_id={{ cart.items.first.product_id }}&limit=4&intent=related">
    {%- comment -%} Content will be injected here via AJAX by CartDrawerRecommendations component {%- endcomment -%}
  </cart-drawer-recommendations>
{%- endif -%}
